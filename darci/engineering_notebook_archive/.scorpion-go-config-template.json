{
  "providers": {
    "gemini": {
      "api_key": "",
      "model": "gemini-2.5-flash"
    }
  },
  "agents": {
    "defaults": {
      "model": "gemini-2.5-flash",
      "temperature": 0.7,
      "max_tokens": 8192,
      "max_tool_iterations": 10,
      "memory_window": 50,
      "reasoning_effort": "medium"
    }
  },
  "channels": {
    "telegram": {
      "enabled": false,
      "token": "",
      "allow_from": [],
      "proxy": null,
      "reply_to_message": false,
      "react_emoji": "👍",
      "voice": {
        "enabled": true,
        "voice": "Kore",
        "always": false
      }
    },
    "slack": {
      "enabled": false,
      "mode": "socket",
      "bot_token": "",
      "app_token": ""
    },
    "email": {
      "enabled": false,
      "consent_granted": false
    }
  },
  "tools": {
    "restrict_to_workspace": false,
    "exec": {
      "timeout": 60
    },
    "web": {
      "search": {
        "api_key": ""
      }
    },
    "mcp_servers": {}
  },
  "gateway": {
    "heartbeat": {
      "enabled": true,
      "interval_s": 60
    }
  },
  "workspace": "~/.darci-go/workspace"
}
