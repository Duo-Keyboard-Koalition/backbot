# Tailscale Authentication Keys
# Generate these from https://login.tailscale.com/admin/settings/keys
# Each agent needs its own unique auth key

TS_AUTH_KEY_1=tskey-auth-xxxxx-agent1
TS_AUTH_KEY_2=tskey-auth-xxxxx-agent2
TS_AUTH_KEY_3=tskey-auth-xxxxx-agent3

# Tailscale Configuration
TAILNET_NAME=your-tailnet.ts.net

# Optional: Extra Tailscale arguments
TS_EXTRA_ARGS=--accept-dns=false
